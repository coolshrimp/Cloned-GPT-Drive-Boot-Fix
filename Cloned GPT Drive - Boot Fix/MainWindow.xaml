<Window x:Class="Cloned_GPT_Drive___Boot_Fix.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cloned_GPT_Drive___Boot_Fix"
        mc:Ignorable="d"
        Title="Cloned GPT Drive - Boot Fix" Height="520.73" Width="736.401" ResizeMode="NoResize">

    <Canvas Height="481" Margin="0,10,4,0" VerticalAlignment="Top">
        <Label x:Name="Drive_Select_LBL" Content="Select Cloned Drive With Windows" HorizontalAlignment="Left" VerticalAlignment="Top" Width="201" Canvas.Left="100" Canvas.Top="4" RenderTransformOrigin="0.811,0.385"/>
        <ComboBox x:Name="DriveSelection_ddbox" Height="23" Canvas.Left="97" Canvas.Top="28" Width="204" SelectionChanged="DriveSelection_ddbox_SelectionChanged"/>
        <ComboBox x:Name="UnusedDriveSelection_ddbox" Canvas.Left="528" Canvas.Top="28" Width="78"/>
        <Button x:Name="Get_Volumes" Content="Get Volumes" Height="23" Canvas.Left="16" Canvas.Top="28" Width="76" Click="Button_Click_1"/>
        <ComboBox x:Name="Volumes_dd" Canvas.Left="306" Canvas.Top="28" Width="217"/>
        <Label x:Name="Drive_Select_LBL_Copy" Content="Select Cloned Drive Fat32 Volume" HorizontalAlignment="Left" VerticalAlignment="Top" Width="201" Canvas.Left="317" Canvas.Top="2" RenderTransformOrigin="0.811,0.385"/>
        <Label x:Name="Drive_Select_LBL_Copy1" Content="Select Letter" HorizontalAlignment="Left" VerticalAlignment="Top" Width="78" Canvas.Left="529" Canvas.Top="1" RenderTransformOrigin="0.811,0.385">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0.742"/>
                    <RotateTransform/>
                    <TranslateTransform Y="1.06"/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
        <Button x:Name="FixBoot_btn" Content="Fix Boot" HorizontalAlignment="Left" VerticalAlignment="Top" Width="105" Canvas.Left="611" Canvas.Top="28" Click="FixBoot_btn_Click" Height="23"/>
        <Label Content="Created By:" Canvas.Left="279" Canvas.Top="445"/>
        <Label x:Name="CreatorLink" Content="Coolshrimp Modz" Canvas.Left="343" Canvas.Top="445" Width="105" Background="White" Foreground="#FF8700E4" MouseDown="CreatorLink_MouseDown"/>

        <TabControl Height="384" Canvas.Left="16" Canvas.Top="56" Width="700">
            <TabItem Header="Simple">
                <TextBox x:Name="StatusBox" TextWrapping="Wrap" x:FieldModifier="public" Canvas.Left="21" Canvas.Top="82" IsReadOnly="True" Margin="0,0,1,0"/>
            </TabItem>

            <TabItem Header="Detailed">
                <TextBox x:Name="CMDOutputBox" TextWrapping="Wrap" x:FieldModifier="public" Canvas.Left="21" Canvas.Top="82" IsReadOnly="True" Margin="0,0,1,0"/>
            </TabItem>

            <TabItem Header="Info" HorizontalAlignment="Left" Height="20" VerticalAlignment="Top" Width="54">
                <TextBox x:Name="Drive_Info" TextWrapping="Wrap" x:FieldModifier="public" Canvas.Left="575" Canvas.Top="79" IsReadOnly="True" Margin="0,0,2,2"/>
            </TabItem>

            <TabItem Header="Guide" HorizontalAlignment="Left" Height="20" VerticalAlignment="Top" Width="54">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="5">
                    <StackPanel Margin="10">
                        <TextBlock FontSize="16" FontWeight="Bold" Margin="0,0,0,10">
                            How to Repair Boot on Cloned GPT Drive
                        </TextBlock>

                        <TextBlock FontSize="12" FontWeight="Bold" Margin="0,10,0,5" Foreground="DarkBlue">
                            Step 1: Prepare Your Cloned Drive
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,5">
                            • Connect your cloned drive to your computer
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,5">
                            • Make sure your cloned drive has Windows installed
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,10">
                            • The drive should have a FAT32 EFI partition (usually 100-500 MB)
                        </TextBlock>

                        <TextBlock FontSize="12" FontWeight="Bold" Margin="0,10,0,5" Foreground="DarkBlue">
                            Step 2: Select the Cloned Drive
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,5">
                            1. In the "Select Cloned Drive With Windows" dropdown at the top
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,10">
                            2. Choose the drive letter where your cloned Windows is installed (e.g., D:\, E:\)
                        </TextBlock>

                        <TextBlock FontSize="12" FontWeight="Bold" Margin="0,10,0,5" Foreground="DarkBlue">
                            Step 3: Get Available Volumes
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,5">
                            1. Click the "Get Volumes" button
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,5">
                            2. This will list all volumes on your system
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,10">
                            3. Look for a FAT32 volume that's around 100-500 MB (this is your EFI partition)
                        </TextBlock>

                        <TextBlock FontSize="12" FontWeight="Bold" Margin="0,10,0,5" Foreground="DarkBlue">
                            Step 4: Select the FAT32 EFI Volume
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,5">
                            1. In the "Select Cloned Drive Fat32 Volume" dropdown
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,10">
                            2. Select the FAT32 volume from your cloned drive (usually "Volume 2" or similar)
                        </TextBlock>

                        <TextBlock FontSize="12" FontWeight="Bold" Margin="0,10,0,5" Foreground="DarkBlue">
                            Step 5: Select a Temporary Drive Letter
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,5">
                            1. In the "Select Letter" dropdown
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,10">
                            2. Choose any available drive letter (e.g., X:\, Y:\, Z:\)
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,10" FontStyle="Italic" Foreground="Gray">
                            Note: This letter is only used temporarily and will be removed automatically
                        </TextBlock>

                        <TextBlock FontSize="12" FontWeight="Bold" Margin="0,10,0,5" Foreground="DarkBlue">
                            Step 6: Fix the Boot
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,5">
                            1. Click the "Fix Boot" button
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,5">
                            2. The tool will:
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="20,0,0,5">
                            • Assign the temporary drive letter to the EFI partition
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="20,0,0,5">
                            • Copy boot files from your Windows installation to the EFI partition
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="20,0,0,5">
                            • Remove the temporary drive letter
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,10">
                            3. Check the "Simple" tab for progress updates
                        </TextBlock>

                        <TextBlock FontSize="12" FontWeight="Bold" Margin="0,10,0,5" Foreground="Green">
                            Done!
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,15">
                            Your cloned drive should now boot properly. You can safely disconnect it and use it in another computer.
                        </TextBlock>

                        <Border BorderBrush="Orange" BorderThickness="2" Padding="10" Margin="0,10,0,10" Background="LightYellow">
                            <StackPanel>
                                <TextBlock FontSize="12" FontWeight="Bold" Foreground="DarkOrange">
                                    ⚠ Safety Features
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="0,5,0,0">
                                    This tool includes protection against accidental data loss:
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="10,5,0,0">
                                    • Protected drives cannot be formatted or cleaned
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="10,0,0,0">
                                    • System drives are automatically protected on first run
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="10,0,0,5">
                                    • Multiple confirmations required for destructive operations
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="0,5,0,0" FontStyle="Italic">
                                    Manage protected drives in the "Extras" tab.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <TextBlock FontSize="10" FontStyle="Italic" Foreground="Gray" Margin="0,10,0,0" TextWrapping="Wrap">
                            Tip: Always run this application as Administrator for full functionality.
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Extras" HorizontalAlignment="Left" Height="20" VerticalAlignment="Top" Width="54" Margin="486,0,-486,0">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Disk Operations Section -->
                    <StackPanel Grid.Row="0" Margin="5">
                        <Label Content="Disk Operations" FontWeight="Bold" FontSize="14"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Button x:Name="Get_Disks_btn" Content="Get Disks" Height="23" Width="76" Click="Get_Disks_btn_Click" Margin="0,0,5,0"/>
                            <Label Content="Select Disk:" VerticalAlignment="Center" Margin="5,0,5,0"/>
                            <ComboBox x:Name="Disk_list_dd" Width="120" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <Button x:Name="ConvertToGPT_btn" Content="Convert To GPT" Width="98" Click="ConvertToGPT_btn_Click" Margin="0,0,5,0"/>
                            <Button x:Name="Clean_Disk_btn" Content="Clean Disk" Width="75" Click="Clean_Disk_btn_Click" Margin="0,0,5,0"/>
                            <Button x:Name="Show_disk_manager_btn" Content="Show Disk Manager" Width="117" Click="Show_disk_manager_btn_Click" Margin="0,0,5,0"/>
                            <Button x:Name="ProtectDisk_btn" Content="Protect Disk's Drives" Width="120" Click="ProtectDisk_btn_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Main content area with splitter -->
                    <Grid Grid.Row="1" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Disk Info Box -->
                        <GroupBox Grid.Column="0" Header="Disk Information" Margin="0,0,2,0">
                            <TextBox x:Name="ExtrasInfoBox" TextWrapping="Wrap" x:FieldModifier="public" IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>
                        </GroupBox>

                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="LightGray"/>

                        <!-- Protected Drives Section -->
                        <GroupBox Grid.Column="2" Header="Protected Drives" Margin="2,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <ListBox x:Name="ProtectedDrives_ListBox" Grid.Row="0" Margin="5" ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                                <StackPanel Grid.Row="1" Margin="5">
                                    <Label Content="Manage Protection:" FontWeight="Bold" FontSize="11" Padding="0,5,0,5"/>
                                    <Button x:Name="RemoveProtection_btn" Content="Remove Selected" Width="120" Height="25" Margin="0,5,0,5" Click="RemoveProtection_btn_Click" HorizontalAlignment="Center"/>
                                    <Button x:Name="RefreshProtected_btn" Content="Refresh List" Width="120" Height="25" Margin="0,0,0,5" Click="RefreshProtected_btn_Click" HorizontalAlignment="Center"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="Gray" Margin="0,10,0,0" TextAlignment="Center">
                                        Protected drives cannot be cleaned or formatted
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>


        </TabControl>


    </Canvas>
</Window>
