<Window x:Class="Cloned_GPT_Drive___Boot_Fix.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cloned_GPT_Drive___Boot_Fix"
        mc:Ignorable="d"
        Title="Cloned GPT Drive - Boot Fix" Height="550" Width="772" ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="GuideTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="StepCard" TargetType="Border">
            <Setter Property="BorderBrush" Value="#FFD0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="#FFF7F9FC"/>
            <Setter Property="Padding" Value="12,8,12,10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="StepHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF2255AA"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="StepBody" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="12,0,0,3"/>
        </Style>
        <Style x:Key="StepNote" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="12,2,0,0"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Resources>

    <Canvas Height="511" Margin="0,10,4,0" VerticalAlignment="Top">
        <Label x:Name="Drive_Select_LBL" Content="Select Cloned Drive With Windows" HorizontalAlignment="Left" VerticalAlignment="Top" Width="201" Canvas.Left="109" Canvas.Top="2" RenderTransformOrigin="0.811,0.385"/>
        <ComboBox x:Name="DriveSelection_ddbox" Height="23" Canvas.Left="97" Canvas.Top="28" Width="225" SelectionChanged="DriveSelection_ddbox_SelectionChanged" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <ComboBox x:Name="UnusedDriveSelection_ddbox" Canvas.Left="567" Canvas.Top="28" Width="78" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <Button x:Name="Refresh_btn" Content="Refresh" Height="23" Canvas.Left="16" Canvas.Top="28" Width="76" Click="Refresh_btn_Click"/>
        <ComboBox x:Name="Volumes_dd" Canvas.Left="327" Canvas.Top="28" Width="235" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <Label x:Name="Drive_Select_LBL_Copy" Content="Select Cloned Drive Fat32 Volume" HorizontalAlignment="Left" VerticalAlignment="Center" Width="201" Canvas.Left="344" Canvas.Top="2" RenderTransformOrigin="0.811,0.385"/>
        <Label x:Name="Drive_Select_LBL_Copy1" Content="Select Letter" HorizontalAlignment="Left" VerticalAlignment="Center" Width="78" Canvas.Left="568" Canvas.Top="1" RenderTransformOrigin="0.811,0.385">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0.742"/>
                    <RotateTransform/>
                    <TranslateTransform Y="1.06"/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
        <Button x:Name="FixBoot_btn" Content="Fix Boot" HorizontalAlignment="Left" VerticalAlignment="Center" Width="105" Canvas.Left="650" Canvas.Top="28" Click="FixBoot_btn_Click" Height="23"/>

        <TextBlock x:Name="Progress_StatusText" Text="Ready." Canvas.Left="16" Canvas.Top="55" Width="500" VerticalAlignment="Center" FontSize="11"/>
        <ProgressBar x:Name="Progress_Bar" Canvas.Left="16" Canvas.Top="75" Width="739" Height="5" Minimum="0" Maximum="100" IsIndeterminate="False" Value="0"/>

        <Label Content="Created By:" Canvas.Left="279" Canvas.Top="475"/>
        <Label x:Name="CreatorLink" Content="Coolshrimp Modz" Canvas.Left="343" Canvas.Top="475" Width="105" Background="White" Foreground="#FF8700E4" MouseDown="CreatorLink_MouseDown"/>

        <TabControl Height="384" Canvas.Left="16" Canvas.Top="86" Width="741" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Left" VerticalAlignment="Center">
            <TabControl.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0.207"/>
                    <RotateTransform/>
                    <TranslateTransform Y="1.264"/>
                </TransformGroup>
            </TabControl.RenderTransform>
            <TabItem Header="Simple">
                <TextBox x:Name="StatusBox" TextWrapping="Wrap" x:FieldModifier="public" Canvas.Left="21" Canvas.Top="82" IsReadOnly="True" Margin="0,0,1,0"/>
            </TabItem>

            <TabItem Header="Log">
                <TextBox x:Name="CMDOutputBox" TextWrapping="Wrap" x:FieldModifier="public" Canvas.Left="21" Canvas.Top="82" IsReadOnly="True" Margin="0,0,1,0"/>
            </TabItem>

            <TabItem Header="Info" HorizontalAlignment="Right" Margin="0,-2,-2,0" Width="36">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Selected Drive:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="Info_SelectedDriveText" Text="(none selected)" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button x:Name="ToggleProtect_btn" Content="🔒 Protect Drive" Width="140" Height="26" Click="ToggleProtect_btn_Click"/>
                    </StackPanel>

                    <GroupBox Grid.Row="1" Header="Drive Details">
                        <TextBox x:Name="Drive_Info" TextWrapping="Wrap" x:FieldModifier="public" IsReadOnly="True" BorderThickness="0" VerticalScrollBarVisibility="Auto"/>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Guide">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="5">
                    <StackPanel Margin="10">
                        <TextBlock Style="{StaticResource GuideTitle}">
                            How to Repair Boot on a Cloned GPT Drive
                        </TextBlock>

                        <Border Style="{StaticResource StepCard}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource StepHeader}">Step 1 — Connect the Drive and Refresh</TextBlock>
                                <TextBlock Style="{StaticResource StepBody}">1. Connect the cloned drive to your computer.</TextBlock>
                                <TextBlock Style="{StaticResource StepBody}">2. Click the "Refresh" button at the top (this also runs automatically when the app launches).</TextBlock>
                                <TextBlock Style="{StaticResource StepBody}">3. This refreshes both drive dropdowns and lists every volume on the system.</TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StepCard}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource StepHeader}">Step 2 — Select Your Cloned Drive</TextBlock>
                                <TextBlock Style="{StaticResource StepBody}">1. In "Select Cloned Drive With Windows", choose the drive letter that needs its boot repaired.</TextBlock>
                                <TextBlock Style="{StaticResource StepNote}">The tool will automatically try to select the matching FAT32 EFI partition for you in the next dropdown.</TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StepCard}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource StepHeader}">Step 3 — Confirm the FAT32 EFI Volume</TextBlock>
                                <TextBlock Style="{StaticResource StepBody}">1. Check "Select Cloned Drive Fat32 Volume" — it should already show the small FAT32 partition (usually 100–500 MB) belonging to your selected drive.</TextBlock>
                                <TextBlock Style="{StaticResource StepBody}">2. If it picked the wrong volume, just change the dropdown yourself.</TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StepCard}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource StepHeader}">Step 4 — Pick a Temporary Mount Letter</TextBlock>
                                <TextBlock Style="{StaticResource StepBody}">1. In "Select Letter", choose any available letter (e.g., X:\, Y:\, Z:\).</TextBlock>
                                <TextBlock Style="{StaticResource StepNote}">This letter is only used temporarily and is removed automatically once the repair finishes.</TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StepCard}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource StepHeader}">Step 5 — Click Fix Boot</TextBlock>
                                <TextBlock Style="{StaticResource StepBody}">Click "Fix Boot". The tool will, in order:</TextBlock>
                                <TextBlock Style="{StaticResource StepBody}" Margin="24,0,0,3">• Mount the FAT32 EFI partition to the temporary letter</TextBlock>
                                <TextBlock Style="{StaticResource StepBody}" Margin="24,0,0,3">• Rebuild boot files from the cloned Windows installation (bcdboot)</TextBlock>
                                <TextBlock Style="{StaticResource StepBody}" Margin="24,0,0,3">• Remove the temporary letter again</TextBlock>
                                <TextBlock Style="{StaticResource StepBody}">Watch the "Simple" tab for live progress, or "Log" for the raw command output.</TextBlock>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="#FF3C9B4C" BorderThickness="1" CornerRadius="4" Background="#FFEAF7EC" Padding="12,8" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock FontSize="13" FontWeight="Bold" Foreground="#FF2E7D32">Done!</TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="0,4,0,0">
                                    Your cloned drive should now boot properly. You can safely disconnect it and use it in another computer.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="#FFE0A100" BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,0,0,10" Background="#FFFFF6DD">
                            <StackPanel>
                                <TextBlock FontSize="13" FontWeight="Bold" Foreground="#FFB07800">
                                    ⚠ Safety Features
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="0,6,0,0">
                                    This tool includes protection against accidental data loss:
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="12,4,0,0">• Protected drives cannot be formatted or cleaned</TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="12,2,0,0">• System drives are automatically protected on first run</TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="12,2,0,0">• Multiple confirmations are required for destructive operations</TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="0,6,0,0" FontStyle="Italic">
                                    Manage protected drives in the "List Disks" tab.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <TextBlock FontSize="10" FontStyle="Italic" Foreground="Gray" Margin="0,4,0,0" TextWrapping="Wrap">
                            Tip: Always run this application as Administrator for full functionality.
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="List Disks">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Disk Operations Section -->
                    <StackPanel Grid.Row="0" Margin="5">
                        <Label Content="Disk Operations" FontWeight="Bold" FontSize="14"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Button x:Name="Get_Disks_btn" Content="🔄 List Disks" Height="23" Width="90" Click="Get_Disks_btn_Click" Margin="0,0,5,0"/>
                            <Label Content="Select Disk:" VerticalAlignment="Center" Margin="5,0,5,0"/>
                            <ComboBox x:Name="Disk_list_dd" Width="120" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <Button x:Name="ConvertToGPT_btn" Content="Convert To GPT" Width="98" Click="ConvertToGPT_btn_Click" Margin="0,0,5,0"/>
                            <Button x:Name="Clean_Disk_btn" Content="Clean Disk" Width="75" Click="Clean_Disk_btn_Click" Margin="0,0,5,0"/>
                            <Button x:Name="Show_disk_manager_btn" Content="Show Disk Manager" Width="117" Click="Show_disk_manager_btn_Click" Margin="0,0,5,0"/>
                            <Button x:Name="ProtectDisk_btn" Content="Protect This Disk" Width="120" Click="ProtectDisk_btn_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Main content area with splitter -->
                    <Grid Grid.Row="1" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Disk Info Box -->
                        <GroupBox Grid.Column="0" Header="Disk Information" Margin="0,0,2,0">
                            <TextBox x:Name="ExtrasInfoBox" TextWrapping="Wrap" x:FieldModifier="public" IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>
                        </GroupBox>

                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="LightGray"/>

                        <!-- Protected Drives Section -->
                        <GroupBox Grid.Column="2" Header="Protected Drives" Margin="2,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <ListBox x:Name="ProtectedDrives_ListBox" Grid.Row="0" Margin="5" ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                                <StackPanel Grid.Row="1" Margin="5">
                                    <Label Content="Manage Protection:" FontWeight="Bold" FontSize="11" Padding="0,5,0,5"/>
                                    <Button x:Name="RemoveProtection_btn" Content="Remove Selected" Width="120" Height="25" Margin="0,5,0,5" Click="RemoveProtection_btn_Click" HorizontalAlignment="Center"/>
                                    <Button x:Name="RefreshProtected_btn" Content="🔄 Rescan &amp; Protect Drives" Width="150" Height="25" Margin="0,0,0,5" Click="RefreshProtected_btn_Click" HorizontalAlignment="Center"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="Gray" Margin="0,10,0,0" TextAlignment="Center">
                                        Protected drives cannot be cleaned or formatted
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>


        </TabControl>


    </Canvas>
</Window>
